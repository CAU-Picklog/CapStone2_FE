# .env.example - 팀원들이 참고하는 환경변수 템플릿
# 이 파일을 복사해서 .env로 만든 후 실제 값을 채워주세요
# cp .env.example .env

# 네이버 지도 JavaScript API 클라이언트 ID
# https://console.ncloud.com/ > AI·NAVER API > Maps > Web Dynamic Map
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=your_naver_map_client_id_here

# 네이버 로컬 검색 API (장소 검색 기능)
# 발급 방법:
#   1. https://developers.naver.com → 애플리케이션 등록
#   2. 사용 API: "검색" 카테고리의 "지역" 선택
#   3. 아래 두 값을 .env에 복사
EXPO_PUBLIC_NAVER_SEARCH_CLIENT_ID=your_naver_search_client_id_here
EXPO_PUBLIC_NAVER_SEARCH_CLIENT_SECRET=your_naver_search_client_secret_here

# 백엔드 API 베이스 URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
